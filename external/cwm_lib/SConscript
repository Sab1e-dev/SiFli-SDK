import os
from building import *
import rtconfig
import logging

# get current dir path
cwd = GetCurrentDir()
src  = []
inc  = [cwd]
objs = []
path = [cwd]
lib = [GroupLibName("CWM_LIB_FULL")]

src = src + Glob('./*.c')

# add group to IDE project
objs = DefineGroup('cyw_lib', src, depend = ['USING_CWM_LIB'], CPPPATH = inc, LIBS = lib, LIBPATH = inc)
Return('objs')