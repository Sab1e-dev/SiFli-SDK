from building import *

# get current directory
cwd = GetCurrentDir()
# The set of source files associated with this SConscript file.
src = []
inc = []
path = []

if GetDepend('BSP_USING_RTTHREAD') and not GetDepend('BF0_LCPU'):
	path = [cwd + '/inc']
	path += [cwd + '/port/fal/inc']
	src  += Glob('port/fal/src/*.c')
	
if GetDepend('PKG_USING_FLASHDB'):
    src += Glob('src/*.c')
	
if GetDepend('BSP_USING_PC_SIMULATOR'):
    SrcRemove(src, 'port/fal/src/fal_flash_sifli_port.c')
else:
    SrcRemove(src, 'port/fal/src/fal_flash_sifli_simu.c')

group = DefineGroup('FlashDB', src, depend = [''], CPPPATH = path)

Return('group')
