; *************************************************************
; *** Scatter-Loading Description File generated by Jinja2 ***
; *************************************************************

{% set lcpu_data_base = defines['__RAM_BASE'] + defines['__ROM_SIZE'] %}
{% set lcpu_data_size = defines['__RAM_SIZE'] - defines['__ROM_SIZE'] %}
{% set lcpu_itcm_size = defines.get('__DTCM_SIZE', defines['__ROM_SIZE']) %}
LR_IROM1 {{ hex32(defines['__ROM_BASE']) }} {{ hex32(defines['__ROM_SIZE']) }} {    ; load region size_region
  ER_IROM0 {{ hex32(defines['__ROM_BASE']) }} {{ hex32(lcpu_itcm_size) }} {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   core_list_join.o (+RO)
   core_main.o (+RO)
   core_matrix.o (+RO)
   core_state.o (+RO)
   core_util.o (+RO)
   main.o (.text.run_while_loop)
   .ANY2 (+RO)
  }
  ER_IROM1 +0   {  ; load address = execution address
   .ANY (+RO)
  }
  ScatterAssert((ImageLength(ER_IROM0)+ImageLength(ER_IROM1))<{{ hex32(defines['__ROM_SIZE']) }})

  RW_DTCM {{ hex32(defines.get('__DTCM_BASE', 0)) }} {{ hex32(defines.get('__DTCM_SIZE', 0)) }} {  ; RW data
   core_list_join.o (+RW +ZI)
   core_main.o (+RW +ZI)
   core_matrix.o (+RW +ZI)
   core_portme.o (+RW +ZI)
   core_state.o (+RW +ZI)
   core_util.o (+RW +ZI)
   main.o (.bss.coremark_stack)
  }

  RW_IRAM1 AlignExpr({{ hex32(defines['__RAM_BASE']) }}+{{ hex32(defines['__ROM_SIZE']) }}, 16) ALIGN 16 NOCOMPRESS {{ hex32(lcpu_data_size) }} {  ; RW data
   .ANY (+RW +ZI)
  }
}
