# CONFIG_SOC_SIMULATOR is not set
CONFIG_SOC_SF32LB57X_GENERIC=y
# CONFIG_SOC_SF32LB573UB7N6 is not set
# CONFIG_SOC_SF32LB573UB776 is not set
