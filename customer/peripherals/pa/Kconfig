    bool  "Digital PA AW882XX Enabled"
    default n
config PA_USING_AW87390
    bool  "Analog PA AW87390 Enabled"
    default n
    if PA_USING_AW87390
        config AW87390_GPIO_PIN
            int "AW87390 Control PIN"
            default 0
    endif 
config PA_USING_AW8155
    bool  "Analog PA AW8155 Enabled"
    default n
    if PA_USING_AW8155
        config AW8155_GPIO_PIN
            int "AW8155 Control PIN"
            default 0
    endif 

endmenu