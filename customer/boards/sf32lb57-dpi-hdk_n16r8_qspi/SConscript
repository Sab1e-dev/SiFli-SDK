from building import *

cwd = GetCurrentDir()

src = Glob('./*.c')

path =  [cwd, 
         os.path.join(cwd, '../include')]

group = DefineGroup('Drivers', src, depend = ['BSP_USING_BOARD_SF32LB57_DPI_HDK_N16R8_QSPI'], CPPPATH = path)

if GetDepend('BSP_USING_BOARD_SF32LB57_DPI_HDK_N16R8_QSPI'):
    group = group + SConscript('../sf32lb57-dpi-hdk_base/SConscript.base')

Return('group')
