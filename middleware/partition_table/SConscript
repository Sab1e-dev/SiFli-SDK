from building import *
Import('rtconfig')
import os
import logging
cwd = GetCurrentDir()
env = GetCurrentEnv()

src_file = None

if GetDepend('USING_PARTITION_TABLE'):
    if GetBoardName():
        if IsChildProjEnv():
            # use parents's ptab if build as child project, parent project always use hcpu board
            board = GetBoardName("HCPU")
            bsp_root = str(Dir('#'))
        else:
            board = GetBoardName()
            bsp_root = env['BSP_ROOT']

        # 优先查找 ptab.yaml (v3)，其次 ptab.json (v1/v2)
        src_file = None
        search_paths = [
            os.path.join(bsp_root, board),
            os.path.join(bsp_root, rtconfig.CHIP.lower()),
            bsp_root,
        ]
        # 添加 board path
        path1, path2 = GetBoardPath(GetBoardName())
        search_paths.append(path1)

        for search_dir in search_paths:
            # 优先 yaml
            yaml_path = os.path.join(search_dir, 'ptab.yaml')
            json_path = os.path.join(search_dir, 'ptab.json')
            if os.path.exists(yaml_path):
                src_file = yaml_path
                break
            elif os.path.exists(json_path):
                src_file = json_path
                break

        if src_file is None:
            # 兼容原有逻辑
            src_file = os.path.join(path1, 'ptab.json')

        logging.debug("ptab file: {}".format(src_file))
        env['PARTITION_TABLE'] = src_file
        output_dir = env['BUILD_DIR_FULL_PATH']
    else:    
        if 'PARTITION_TABLE' in env:
            src_file = os.path.join(env['PARTITION_TABLE'])
            output_dir = os.path.join(env['BSP_ROOT'], './linker_scripts')
        else:
            # 优先 yaml
            yaml_path = os.path.join(env['BSP_ROOT'], './linker_scripts/ptab.yaml')
            json_path = os.path.join(env['BSP_ROOT'], './linker_scripts/ptab.json')
            if os.path.exists(yaml_path):
                src_file = yaml_path
            else:
                src_file = json_path
            env['PARTITION_TABLE'] = src_file
            output_dir = os.path.join(env['BSP_ROOT'], './linker_scripts')    

    try:
        import ptab as ptab_module
        ptab_obj = ptab_module.load_ptab(src_file, fatal=False) if src_file else None
    except Exception:
        ptab_obj = None

    cppdefines = list(env.get('CPPDEFINES', []))
    filtered_cppdefines = []
    for item in cppdefines:
        define_name = item[0] if isinstance(item, tuple) else item
        if define_name != 'USING_PTAB_V3':
            filtered_cppdefines.append(item)
    env['CPPDEFINES'] = filtered_cppdefines

    if ptab_obj and ptab_obj.is_v3():
        env.AppendUnique(CPPDEFINES=['USING_PTAB_V3'])

    ptab_header = env.PtabHeader(os.path.join(output_dir, 'ptab.h'), File(src_file))
    env['PTAB_HEADER'] = ptab_header

    # 生成 ftab.bin（仅 ptab v3 + 主项目中，避免与子项目冲突）
    if not IsChildProjEnv():
        if ptab_obj and ptab_obj.is_v3():
            imgs_info = []
            target_list = []
            for e in GetEnvList():
                # embedded project binaries are embedded into parent image
                if IsChildProjEnv(e) and e.get('IMG_EMBEDDED'):
                    continue
                proj_name = e['name'] if IsChildProjEnv(e) else 'main'
                if 'program_binary' in e:
                    imgs_info.append({"name": proj_name, "binary": e['program_binary']})
                if 'target' in e:
                    target_list += e['target']
                if 'program_binary' in e:
                    target_list += e['program_binary']
                if 'program_hex' in e:
                    target_list += e['program_hex']
            ftab_bin = env.FtabBin(os.path.join(output_dir, 'ftab.bin'), File(src_file), IMGS_INFO=imgs_info)
            Depends(ftab_bin, target_list)
            env['FTAB_BIN'] = ftab_bin

group = []
    
Return('group')
